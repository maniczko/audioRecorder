{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../dist-server",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": true
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.js"]
}
