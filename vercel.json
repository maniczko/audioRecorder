{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "vite",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./src ./public ./package.json ./pnpm-lock.yaml ./index.html ./vite.config.js",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://audiorecorder-production.up.railway.app/:path*"
    }
  ]
}
