{
  "name": "voicelog-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@xenova/transformers": "^2.17.2",
    "dompurify": "^3.3.3",
    "hono": "^4.12.8",
    "idb-keyval": "^6.2.2",
    "onnxruntime-node": "^1.24.3",
    "pg": "^8.20.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "react-window": "^2.2.7",
    "web-vitals": "^2.1.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "workspaces": [
    "server"
  ],
  "scripts": {
    "start": "vite",
    "start:server": "tsx server/index.ts",
    "start:server:watch": "tsx --watch server/index.ts",
    "build:server": "find server -name \"*.ts\" -o -name \"*.js\" | xargs pnpm exec esbuild --outdir=dist-server --platform=node --format=cjs",
    "start:server:prod": "node dist-server/index.js",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:seed": "tsx server/scripts/seed.ts",
    "test:smoke": "tsx server/scripts/smoke-test.ts",
    "build": "vite build",
    "turbo:build": "turbo run build",
    "lint": "eslint src --max-warnings=0",
    "turbo:lint": "turbo run lint",
    "test": "npm run lint && vitest run",
    "turbo:test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:server": "vitest run -c server/vitest.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "vitest related --run"
    ],
    "server/**/*.{js,ts}": [
      "vitest related --run"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
