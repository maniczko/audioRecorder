{
  "name": "voicelog-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.2",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.35",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/langgraph-cli": "^1.1.17",
    "@langchain/openai": "^1.3.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "@supabase/supabase-js": "^2.100.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "hono": "^4.12.8",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.0.1",
    "nodemailer": "^8.0.3",
    "octokit": "^5.0.5",
    "onnxruntime-node": "^1.24.3",
    "pg": "^8.20.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "react-window": "^2.2.7",
    "shadcn": "^4.1.1",
    "simple-rnnoise-wasm": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^2.1.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "workspaces": [
    "server"
  ],
  "scripts": {
    "start": "vite",
    "start:server": "tsx server/index.ts",
    "start:server:watch": "tsx --watch server/index.ts",
    "start:server:datadog": "DD_APM_ENABLED=true tsx --require ./server/datadog.ts server/index.ts",
    "start:server:newrelic": "NEW_RELIC_ENABLED=true tsx --require ./newrelic.cjs server/index.ts",
    "start:0x": "npx 0x dist-server/index.js",
    "start:clinic": "npx clinic doctor -- node dist-server/index.js",
    "setup:apm:datadog": "pnpm add dd-trace && echo 'See APM_INTEGRATION.md for configuration'",
    "setup:apm:newrelic": "pnpm add newrelic && echo 'See APM_INTEGRATION.md for configuration'",
    "tdd": "bash scripts/tdd-check.sh",
    "tdd:check": "bash scripts/tdd-check.sh",
    "test:regression": "vitest run server/tests/regression/",
    "test:performance": "vitest run server/tests/performance/ --reporter=verbose",
    "test:performance:ci": "vitest run server/tests/performance/ --reporter=json --outputFile=reports/performance-results.json",
    "test:smoke": "tsx server/scripts/smoke-test.ts",
    "audit:a11y": "node scripts/accessibility-audit.cjs",
    "audit:a11y:ci": "node scripts/accessibility-audit.cjs --ci",
    "audit:lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./reports/lighthouse-report.html",
    "cleanup:disk": "node scripts/cleanup-disk-space.js",
    "cleanup:disk:urgent": "node scripts/cleanup-disk-space.js 1",
    "build": "vite build",
    "build:clean": "rm -rf node_modules/.vite dist build && vite build",
    "build:fix": "rm -rf node_modules/.vite && pnpm run build",
    "start:clean": "rm -rf node_modules/.vite && vite",
    "turbo:build": "turbo run build",
    "migrate": "node scripts/code-migration.cjs",
    "migrate:dry": "node scripts/code-migration.cjs --dry-run",
    "docs:generate": "node scripts/auto-docs.cjs",
    "docs:watch": "node scripts/auto-docs.cjs --verbose",
    "post-deploy": "node scripts/post-deploy.js",
    "db:migrate": "node scripts/post-deploy.js",
    "db:seed": "node scripts/seed-database.js",
    "db:check": "node scripts/check-database.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "changelog:init": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "release": "pnpm run changelog && git add CHANGELOG.md",
    "errors:fetch": "node scripts/fetch-github-errors.js",
    "errors:report": "node scripts/fetch-github-errors.js --verbose",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"server/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\" \"server/**/*.{ts,js}\"",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lint": "eslint src --max-warnings=50 --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.tsx' --ignore-pattern '**/*.spec.ts'",
    "lint:fix": "eslint src --fix --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.tsx' --ignore-pattern '**/*.spec.ts'",
    "lint:staged": "bash scripts/smart-lint.sh",
    "lint:all": "eslint src --max-warnings=0",
    "turbo:lint": "turbo run lint",
    "test": "pnpm run lint && vitest run",
    "test:fix": "pnpm run lint:fix && pnpm run format && vitest run",
    "test:ai-fix": "pnpm run lint:fix && pnpm run format && pnpm run test:smart-retry",
    "test:retry": "vitest run --retry=3 --reporter=verbose",
    "test:smart-retry": "node scripts/smart-retry.cjs",
    "test:coverage:fix": "pnpm run lint:fix && pnpm run format && pnpm run test:coverage",
    "turbo:test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:server": "vitest run -c server/vitest.config.ts --coverage",
    "test:coverage:all": "pnpm run test:coverage:server && pnpm run test:coverage",
    "coverage:report": "scripts\\generate-coverage-report.bat",
    "coverage:open": "start coverage\\server\\index.html",
    "coverage:open:frontend": "start coverage\\frontend\\index.html",
    "coverage:summary": "node scripts/coverage-summary.cjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:advanced": "playwright test tests/e2e/advanced-journeys.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run tests/load/api-load-test.js",
    "test:load:stress": "k6 run tests/load/api-stress-test.js",
    "test:load:soak": "k6 run --duration 1h tests/load/api-load-test.js",
    "test:load:ci": "k6 run --out json=reports/k6-results.json tests/load/api-load-test.js",
    "test:server": "vitest run -c server/vitest.config.ts",
    "test:server:retry": "vitest run -c server/vitest.config.ts --retry=3",
    "test:server:coverage": "vitest run -c server/vitest.config.ts --coverage",
    "test:workflows": "node scripts/validate-vercel-workflows.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --project server/tsconfig.server.json --noEmit",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:server",
    "typecheck:watch": "tsc --noEmit --watch",
    "prepare": "husky",
    "errors:railway": "node scripts/fetch-railway-errors.js",
    "errors:railway:json": "node scripts/fetch-railway-errors.js --json",
    "errors:monitor": "echo \"Error Monitor runs every 6 hours via GitHub Actions\""
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^16.4.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run --retry=3"
    ],
    "server/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run --retry=3"
    ]
  },
  "coverage": {
    "summary": "pnpm run test:coverage:server && node scripts/coverage-summary.cjs"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
