{
  "name": "voicelog-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/community": "^1.1.25",
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/langgraph-cli": "^1.1.16",
    "@langchain/openai": "^1.3.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@supabase/supabase-js": "^2.100.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "hono": "^4.12.9",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "nodemailer": "^8.0.4",
    "octokit": "^5.0.5",
    "onnxruntime-node": "^1.24.3",
    "pg": "^8.20.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "react-window": "^2.2.7",
    "shadcn": "^4.1.0",
    "simple-rnnoise-wasm": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^2.1.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "workspaces": [
    "server"
  ],
  "scripts": {
    "start": "vite",
    "start:server": "tsx server/index.ts",
    "start:server:watch": "tsx --watch server/index.ts",
    "build:server": "find server -name \"*.ts\" -o -name \"*.js\" | xargs pnpm exec esbuild --outdir=dist-server --platform=node --format=cjs",
    "start:server:prod": "node dist-server/index.js",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:seed": "tsx server/scripts/seed.ts",
    "inspect:recordings": "tsx server/scripts/inspect-latest-recordings.ts",
    "benchmark:stt:pl": "tsx server/scripts/benchmark-polish-stt.ts",
    "test:smoke": "tsx server/scripts/smoke-test.ts",
    "cleanup:disk": "node scripts/cleanup-disk-space.js",
    "cleanup:disk:urgent": "node scripts/cleanup-disk-space.js 1",
    "build": "vite build",
    "turbo:build": "turbo run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"server/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\" \"server/**/*.{ts,js}\"",
    "commitlint": "commitlint --edit",
    "lint": "eslint src --max-warnings=0 --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.tsx' --ignore-pattern '**/*.spec.ts'",
    "lint:fix": "eslint src --fix --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.tsx' --ignore-pattern '**/*.spec.ts'",
    "lint:all": "eslint src --max-warnings=0",
    "turbo:lint": "turbo run lint",
    "test": "npm run lint && vitest run",
    "test:fix": "npm run lint:fix && npm run format && vitest run",
    "test:ai-fix": "npm run lint:fix && npm run format && npm run test:smart-retry",
    "test:retry": "vitest run --retry=3 --reporter=verbose",
    "test:smart-retry": "node scripts/smart-retry.js",
    "test:coverage:fix": "npm run lint:fix && npm run format && npm run test:coverage",
    "turbo:test": "turbo run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:server": "vitest run -c server/vitest.config.ts --coverage",
    "test:coverage:all": "npm run test:coverage:server && npm run test:coverage",
    "coverage:report": "scripts\\generate-coverage-report.bat",
    "coverage:open": "start coverage\\server\\index.html",
    "coverage:open:frontend": "start coverage\\frontend\\index.html",
    "coverage:summary": "node scripts/coverage-summary.cjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:server": "vitest run -c server/vitest.config.ts",
    "test:server:retry": "vitest run -c server/vitest.config.ts --retry=3",
    "test:server:coverage": "vitest run -c server/vitest.config.ts --coverage",
    "test:workflows": "node scripts/validate-vercel-workflows.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "rollup-plugin-visualizer": "^5.11.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run --retry=3"
    ],
    "server/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run --retry=3"
    ]
  },
  "coverage": {
    "summary": "npm run test:coverage:server && node scripts/coverage-summary.cjs"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}