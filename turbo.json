{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": [".vite/**", "build/**"],
      "inputs": ["src/**", "index.html", "vite.config.js", "package.json"]
    },
    "build:server": {
      "outputs": ["dist-server/**"],
      "inputs": ["server/**"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", ".eslintrc.json", "package.json"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.js"]
    },
    "test:server": {
      "outputs": [],
      "inputs": ["server/**", "vitest.config.js"]
    },
    "typecheck": {
      "outputs": [],
      "inputs": ["server/**", "src/**", "tsconfig.json"]
    }
  }
}
