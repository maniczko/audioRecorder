#!/bin/sh

# Pre-push hook - runs release guard before allowing push
# This prevents pushing code with failing critical checks

echo "Running release guard before push..."
pnpm run test:release:guard

if [ $? -ne 0 ]; then
  echo "Release guard failed! Push blocked."
  echo "Fix the failing checks and try again."
  exit 1
fi

echo "Release guard passed! Push allowed."
exit 0
