# ==========================================
# VoiceLog OS - Szablon Konfiguracji
# ==========================================
# Skopiuj ten plik jako .env i uzupełnij swoimi kluczami API
# ==========================================

# ─────────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────────

# API Provider mode: "local" (localStorage) lub "remote" (API)
VITE_DATA_PROVIDER=remote

# Media Provider mode: "local" (IndexedDB) lub "remote" (API)
VITE_MEDIA_PROVIDER=remote

# Backend API base URL
VITE_API_BASE_URL=http://127.0.0.1:4000

# Google OAuth Client ID (do kalendarza Google)
# 🔑 Jak uzyskać: https://console.cloud.google.com/apis/credentials
# 1. Zaloguj się do Google Cloud Console
# 2. Utwórz nowy projekt lub wybierz istniejący
# 3. Włącz Google Calendar API
# 4. Utwórz OAuth 2.0 Client ID
# 5. Skopiuj Client ID
VITE_GOOGLE_CLIENT_ID=TWOJ_GOOGLE_CLIENT_ID

# ─────────────────────────────────────────────────────────────
# BACKEND (Server)
# ─────────────────────────────────────────────────────────────

# Server port
VOICELOG_API_PORT=4000
VOICELOG_API_HOST=127.0.0.1
VOICELOG_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database - Supabase PostgreSQL
# 🔑 Jak uzyskać: https://supabase.com/dashboard
# 1. Zaloguj się do Supabase
# 2. Utwórz nowy projekt
# 3. Przejdź do Settings > Database
# 4. Skopiuj Connection string (URI)
DATABASE_URL=postgresql://postgres.TWOJ_PROJEKT:TWOJ_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Supabase URL i Service Role Key
# 🔑 Jak uzyskać: https://supabase.com/dashboard/project/TWOJ_ID/settings/api
SUPABASE_URL=https://TWOJ_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TWOJ_SERVICE_ROLE_KEY

# Local database fallback (SQLite - awaryjne)
VOICELOG_DB_PATH=./server/data/voicelog.sqlite

# Upload directory
VOICELOG_UPLOAD_DIR=./server/data/uploads

# Processing mode: "fast" (szybki) lub "full" (dokładny)
VOICELOG_PROCESSING_MODE_DEFAULT=fast

# STT Provider: "openai" lub "groq" (groq jest darmowe i szybsze)
VOICELOG_STT_PROVIDER=groq
VOICELOG_STT_FALLBACK_PROVIDER=openai

# Debug mode
VOICELOG_DEBUG=true

# ─────────────────────────────────────────────────────────────
# AI/ML API KEYS (wymagane)
# ─────────────────────────────────────────────────────────────

# OpenAI API key (Whisper STT + GPT analizy)
# 🔑 Jak uzyskać: https://platform.openai.com/api-keys
# 1. Zaloguj się do OpenAI Platform
# 2. Przejdź do API Keys
# 3. Utwórz nowy klucz
# 4. Skopiuj klucz (zaczyna się od sk-proj-)
OPENAI_API_KEY=sk-proj-TWOJ_OPENAI_API_KEY
VOICELOG_OPENAI_API_KEY=sk-proj-TWOJ_OPENAI_API_KEY
VOICELOG_OPENAI_BASE_URL=https://api.openai.com/v1

# Groq API key (szybszy Whisper - darmowy)
# 🔑 Jak uzyskać: https://console.groq.com/keys
# 1. Zaloguj się do Groq Console
# 2. Przejdź do API Keys
# 3. Utwórz nowy klucz
# 4. Skopiuj klucz (zaczyna się od gsk_)
GROQ_API_KEY=gsk_TWOJ_GROQ_API_KEY

# Anthropic API key (Claude - analizy psychologiczne)
# 🔑 Jak uzyskać: https://console.anthropic.com/settings/keys
# 1. Zaloguj się do Anthropic Console
# 2. Przejdź do API Keys
# 3. Utwórz nowy klucz
# 4. Skopiuj klucz (zaczyna się od sk-ant-)
ANTHROPIC_API_KEY=sk-ant-api03-TWOJ_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Generative AI (Gemini - alternatywa dla Claude)
# 🔑 Jak uzyskać: https://makersuite.google.com/app/apikey
# 1. Zaloguj się do Google AI Studio
# 2. Przejdź do Get API Key
# 3. Utwórz nowy klucz
# 4. Skopiuj klucz (zaczyna się od AIzaSy)
GEMINI_API_KEY=AIzaSyTWOJ_GEMINI_KEY
GOOGLE_API_KEY=AIzaSyTWOJ_GEMINI_KEY
GOOGLE_GENAI_API_KEY=AIzaSyTWOJ_GEMINI_KEY

# HuggingFace token (Pyannote - diarizacja speakerów)
# 🔑 Jak uzyskać: https://huggingface.co/settings/tokens
# 1. Zaloguj się do HuggingFace
# 2. Przejdź do Settings > Access Tokens
# 3. Utwórz nowy token (typ: Read)
# 4. Zaakceptuj licencję Pyannote
# 5. Skopiuj token (zaczyna się od hf_)
HF_TOKEN=hf_TWOJ_HUGGINGFACE_TOKEN
HUGGINGFACE_TOKEN=hf_TWOJ_HUGGINGFACE_TOKEN

# ─────────────────────────────────────────────────────────────
# DIARIZATION & SPEAKER MODELS
# ─────────────────────────────────────────────────────────────

# Diarization model (Pyannote)
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
SPEAKER_IDENTIFICATION_MODEL=microsoft/wavlm-base-plus-sv
VERIFICATION_MODEL=gpt-4o-transcribe

# Audio processing
AUDIO_LANGUAGE=pl
FFMPEG_BINARY=ffmpeg
PYTHON_BINARY=python

# VAD (Voice Activity Detection)
VAD_ENABLED=true
VOICELOG_SILENCE_REMOVE=true

# Chunking
VOICELOG_CHUNK_OVERLAP_SECONDS=5
VOICELOG_ADAPTIVE_OVERLAP=true
VOICELOG_ENABLE_CHUNK_VAD=false
VOICELOG_ENABLE_POSTPROCESS=true

# ─────────────────────────────────────────────────────────────
# LANGCHAIN & LANGSMITH (monitoring AI)
# ─────────────────────────────────────────────────────────────

# 🔑 Jak uzyskać: https://smith.langchain.com/settings
# 1. Zaloguj się do LangSmith
# 2. Przejdź do Settings > API
# 3. Skopiuj API Key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_TWOJ_LANGSMITH_KEY
LANGCHAIN_PROJECT=voicelog-os

# ─────────────────────────────────────────────────────────────
# GITHUB INTEGRATION (AI dispatcher)
# ─────────────────────────────────────────────────────────────

# 🔑 Jak uzyskać: https://github.com/settings/tokens
# 1. Zaloguj się do GitHub
# 2. Przejdź do Settings > Developer settings > Personal access tokens
# 3. Generate new token (classic)
# 4. Wybierz scope: repo, workflow
# 5. Skopiuj token (zaczyna się od github_pat_)
GITHUB_TOKEN=github_pat_TWOJ_GITHUB_TOKEN

# ─────────────────────────────────────────────────────────────
# LANGGRAPH (AI agent)
# ─────────────────────────────────────────────────────────────

LANGGRAPH_ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────
# LOKALNY WHISPER (opcjonalne - bez API)
# ─────────────────────────────────────────────────────────────

# Enable local Whisper (offline processing)
USE_LOCAL_WHISPER=false

# Path to whisper.cpp binary
# WHISPER_CPP_PATH=C:/whisper.cpp/main.exe

# Path to Whisper model
# WHISPER_MODEL_PATH=./models/ggml-base.bin

# CPU threads
# WHISPER_THREADS=4
