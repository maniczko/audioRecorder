# VoiceLog Server Environment Variables
# Copy this file to .env and fill in the values

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
VOICELOG_API_PORT=4000
VOICELOG_API_HOST=0.0.0.0
VOICELOG_ALLOWED_ORIGINS=http://localhost:3000
VOICELOG_TRUST_PROXY=false

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Use one of these options:
# Option 1: External PostgreSQL (production)
# VOICELOG_DATABASE_URL=postgresql://user:password@localhost:5432/voicelog
# Option 2: Local SQLite (development)
VOICELOG_DB_PATH=./server/data/voicelog.sqlite

# ─────────────────────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────────────────────
# Supabase for persistent remote storage (required for Railway/Vercel)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# STT Providers (Speech-to-Text)
# ─────────────────────────────────────────────────────────────────────────────
# At least one STT provider must be configured
VOICELOG_STT_PROVIDER=openai
VOICELOG_STT_FALLBACK_PROVIDER=none

# OpenAI (required if VOICELOG_STT_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# VOICELOG_OPENAI_API_KEY=sk-...
# VOICELOG_OPENAI_BASE_URL=https://api.openai.com/v1

# Groq (optional, for faster/cheaper STT)
# GROQ_API_KEY=gsk_...

# STT Model configuration
VOICELOG_STT_MODEL_FAST=whisper-tiny
VOICELOG_STT_MODEL_FULL=whisper-1
STT_CONCURRENCY_LIMIT=2

# ─────────────────────────────────────────────────────────────────────────────
# AI / LLM (optional — for meeting analysis, transcript correction)
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ─────────────────────────────────────────────────────────────────────────────
# Speaker Diarization (optional — for speaker identification)
# ─────────────────────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# HUGGINGFACE_TOKEN=hf_...
# DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# ─────────────────────────────────────────────────────────────────────────────
# Audio Processing (optional)
# ─────────────────────────────────────────────────────────────────────────────
# FFMPEG_BINARY=ffmpeg
# PYTHON_BINARY=python
# VOICELOG_CHUNK_OVERLAP_SECONDS=5
# VOICELOG_ADAPTIVE_OVERLAP=true

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (optional — for error tracking)
# ─────────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─────────────────────────────────────────────────────────────────────────────
# DataDog APM (optional — for observability)
# ─────────────────────────────────────────────────────────────────────────────
# DD_API_KEY=your-datadog-api-key
# DD_SERVICE=voicelog-server
# DD_ENV=development
# DD_APM_ENABLED=false
