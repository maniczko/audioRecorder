# VoiceLog API Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
VOICELOG_API_PORT=4000
VOICELOG_API_HOST=0.0.0.0
VOICELOG_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VOICELOG_DEBUG=false

# ─────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────
# Option 1: Local SQLite (default)
VOICELOG_DB_PATH=/data/voicelog.sqlite

# Option 2: PostgreSQL (uncomment to use)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# VOICELOG_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────────
# File Uploads
# ─────────────────────────────────────────────────────────────
VOICELOG_UPLOAD_DIR=/data/uploads

# ─────────────────────────────────────────────────────────────
# Supabase (Optional - for remote storage)
# ─────────────────────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# AI/ML API Keys (Required for transcription features)
# ─────────────────────────────────────────────────────────────
# At least one STT provider is required
OPENAI_API_KEY=sk-...  # Required for Whisper STT
# GROQ_API_KEY=gsk_...  # Optional: alternative STT provider

# Required for speaker diarization
HF_TOKEN=hf_...  # HuggingFace token for pyannote

# Optional: for AI task suggestions and analysis
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────
# STT Provider Configuration
# ─────────────────────────────────────────────────────────────
VOICELOG_STT_PROVIDER=openai
VOICELOG_STT_FALLBACK_PROVIDER=none
# VOICELOG_STT_MODEL_FAST=whisper-1
# VOICELOG_STT_MODEL_FULL=whisper-1
STT_CONCURRENCY_LIMIT=6

# ─────────────────────────────────────────────────────────────
# Processing Configuration
# ─────────────────────────────────────────────────────────────
VOICELOG_PROCESSING_MODE_DEFAULT=fast
VOICELOG_ENABLE_POSTPROCESS=true
VOICELOG_PER_SPEAKER_NORM=true
VOICELOG_SILENCE_REMOVE=true
VAD_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Audio Processing
# ─────────────────────────────────────────────────────────────
FFMPEG_BINARY=ffmpeg
PYTHON_BINARY=python
AUDIO_LANGUAGE=pl
VOICELOG_DIARIZER=auto

# ─────────────────────────────────────────────────────────────
# Session & Security
# ─────────────────────────────────────────────────────────────
# VOICELOG_SESSION_TTL_HOURS=24
# VOICELOG_TRUST_PROXY=false

# ─────────────────────────────────────────────────────────────
# Monitoring & Tracing (Optional)
# ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=your-project

# ─────────────────────────────────────────────────────────────
# Google Integration (Optional)
# ─────────────────────────────────────────────────────────────
# VITE_GOOGLE_CLIENT_ID=your-client-id
# REACT_APP_GOOGLE_CLIENT_ID=your-client-id

# ─────────────────────────────────────────────────────────────
# LangGraph (Optional)
# ─────────────────────────────────────────────────────────────
# LANGGRAPH_ALLOWED_ORIGINS=*
