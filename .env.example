# VoiceLog OS - Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────────

# API Provider mode: "local" (localStorage) or "remote" (API)
VITE_DATA_PROVIDER=remote

# Media Provider mode: "local" (IndexedDB) or "remote" (API)
VITE_MEDIA_PROVIDER=remote

# Backend API base URL
VITE_API_BASE_URL=http://localhost:4000

# Google OAuth Client ID (for Calendar/Tasks integration)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────────────────────────
# BACKEND (Server) - server/.env
# ─────────────────────────────────────────────────────────────

# Server port
PORT=4000

# API host binding
VOICELOG_API_HOST=0.0.0.0

# API port (alternative to PORT)
VOICELOG_API_PORT=4000

# Database path (SQLite)
VOICELOG_DB_PATH=./data/voicelog.sqlite

# Upload directory for audio files
VOICELOG_UPLOAD_DIR=./data/uploads

# Processing mode: "local" or "remote"
VOICELOG_PROCESSING_MODE_DEFAULT=remote

# Debug mode
VOICELOG_DEBUG=false

# ─────────────────────────────────────────────────────────────
# AI/ML API KEYS
# ─────────────────────────────────────────────────────────────

# OpenAI API key (for Whisper STT and GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Preferred alias for backend OpenAI calls
VOICELOG_OPENAI_API_KEY=

# OpenAI base URL (optional, for proxies/alternatives)
VOICELOG_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API key (for Claude models - analysis & summaries)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq API key (for fast LLM inference)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Google Generative AI API key (for Gemini models)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=

# HuggingFace token (for Pyannote diarization)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# Alternative name for HuggingFace token
HUGGINGFACE_TOKEN=

# ─────────────────────────────────────────────────────────────
# LANGCHAIN & LANGSMITH (Optional)
# ─────────────────────────────────────────────────────────────

# Enable LangSmith tracing
LANGSMITH_TRACING=false

# LangSmith API key
# Get from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=

# LangSmith project name
LANGSMITH_PROJECT=voicelog

# ─────────────────────────────────────────────────────────────
# DATABASE (Optional - for PostgreSQL)
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection URL (if not using SQLite)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# EMAIL/NOTIFICATIONS (Optional)
# ─────────────────────────────────────────────────────────────

# SMTP host for sending emails
SMTP_HOST=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP user
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# Email "from" address
SMTP_FROM=noreply@voicelog.local

# ─────────────────────────────────────────────────────────────
# GITHUB INTEGRATION (Optional - for AI dispatcher)
# ─────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────
# SENTRY (Optional - error tracking)
# ─────────────────────────────────────────────────────────────

# Sentry DSN
SENTRY_DSN=

# Sentry environment
SENTRY_ENVIRONMENT=development
